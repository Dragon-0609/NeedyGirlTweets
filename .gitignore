## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.suo
*.user
*.sln.docstates

# Build results

[Dd]ebug/
[Rr]elease/
x64/
[Bb]in/
[Oo]bj/
.idea/

# MSTest test Results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

*_i.c
*_p.c
*_i.h
*.ilk
*.obj
*.pch
*.pdb
*.pgc
*.pgd
*.rsp
*.sbr
*.tlb
*.tli
*.tlh
*.tmp
*.tmp_proj
*.log
*.vspscc
*.vssscc
.builds
*.pidb
*.log
*.svclog
*.scc

# Visual C++ cache files
ipch/
*.aps
*.ncb
*.opensdf
*.sdf
*.cachefile

# Visual Studio profiler
*.psess
*.vsp
*.vspx

# Guidance Automation Toolkit
*.gpState

# ReSharper is a .NET coding add-in
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user

# Click-Once directory
publish/

# Publish Web Output
*.Publish.xml
*.pubxml
*.azurePubxml

# NuGet Packages Directory
## TODO: If you have NuGet Package Restore enabled, uncomment the next line
packages/
## TODO: If the tool you use requires repositories.config, also uncomment the next line
!packages/repositories.config

# Windows Azure Build Output
csx/
*.build.csdef

# Windows Store app package directory
AppPackages/

# Others
sql/
*.Cache
ClientBin/
[Ss]tyle[Cc]op.*
![Ss]tyle[Cc]op.targets
~$*
*~
*.dbmdl
*.[Pp]ublish.xml

*.publishsettings

# RIA/Silverlight projects
Generated_Code/

# Backup & report files from converting an old project file to a newer
# Visual Studio version. Backup files are not needed, because we have git ;-)
_UpgradeReport_Files/
Backup*/
UpgradeLog*.XML
UpgradeLog*.htm

# SQL Server files
App_Data/*.mdf
App_Data/*.ldf

# =========================
# Windows detritus
# =========================

# Windows image file caches
Thumbs.db
ehthumbs.db

# Folder config file
Desktop.ini

# Recycle Bin used on file shares
$RECYCLE.BIN/

# Mac desktop service store files
.DS_Store

_NCrunch*


# Unity

# This .gitignore file should be placed at the root of your Unity project directory
#
# Get latest from https://github.com/github/gitignore/blob/main/Unity.gitignore
#
# Recommended: add any editor/OS/tool-specific ignore rules from the Global/ templates as needed.
# See: https://github.com/github/gitignore/tree/main/Global
#
Unity/.utmp/
Unity/.idea/
Unity/[Ll]ibrary/
Unity/[Ll]ibrary[123456789]/
Unity/[Tt]emp/
Unity/[Oo]bj/
Unity/[Bb]uild/
Unity/[Bb]uilds/
Unity/[Ll]ogs/
Unity/[Uu]ser[Ss]ettings/
Unity/ProfilerCaptures/
Unity/*.log

# By default unity supports Blender asset imports, *.blend1 blender files do not need to be commited to version control.
Unity/*.blend1
Unity/*.blend1.meta

# MemoryCaptures can get excessive in size.
# They also could contain extremely sensitive data
Unity/[Mm]emoryCaptures/

# Recordings can get excessive in size
Unity/[Rr]ecordings/

# Uncomment this line if you wish to ignore the asset store tools plugin
# /[Aa]ssets/AssetStoreTools*

# Autogenerated Jetbrains Rider plugin
Unity/[Aa]ssets/Plugins/Editor/JetBrains*
# Jetbrains Rider personal-layer settings
Unity/*.DotSettings.user

# Visual Studio cache directory
Unity/.vs/

# Gradle cache directory
Unity/.gradle/

# Autogenerated VS/MD/Consulo solution and project files
Unity/ExportedObj/
Unity/.consulo/
Unity/*.csproj
Unity/*.unityproj
Unity/*.sln
Unity/*.slnx
Unity/*.suo
Unity/*.tmp
Unity/*.user
Unity/*.userprefs
Unity/*.pidb
Unity/*.booproj
Unity/*.svd
Unity/*.pdb
Unity/*.mdb
Unity/*.opendb
Unity/*.VC.db

# Unity3D generated meta files
Unity/*.pidb.meta
Unity/*.pdb.meta
Unity/*.mdb.meta

# Unity3D generated file on crash reports
Unity/sysinfo.txt

# Mono auto generated files
Unity/mono_crash.*

# Builds
Unity/*.apk
Unity/*.aab
Unity/*.unitypackage
Unity/*.unitypackage.meta
Unity/*.app

# Crashlytics generated file
Unity/crashlytics-build.properties

# TestRunner generated files
Unity/InitTestScene*.unity*

# Addressables default ignores, before user customizations
Unity/ServerData
Unity/[Aa]ssets/StreamingAssets/aa*
Unity/[Aa]ssets/AddressableAssetsData/link.xml*
Unity/[Aa]ssets/Addressables_Temp*
# By default, Addressables content builds will generate addressables_content_state.bin
# files in platform-specific subfolders, for example:
# /Assets/AddressableAssetsData/OSX/addressables_content_state.bin
Unity/[Aa]ssets/AddressableAssetsData/*/*.bin*

# Visual Scripting auto-generated files
Unity/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Flow/UnitOptions.db
Unity/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Flow/UnitOptions.db.meta
Unity/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Core/Property Providers
Unity/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Core/Property Providers.meta

# Auto-generated scenes by play mode tests
Unity/[Aa]ssets/[Ii]nit[Tt]est[Ss]cene*.unity*

# Auto-generated cache in Assets folder
Unity/[Aa]ssets/[Ss]ceneDependencyCache*